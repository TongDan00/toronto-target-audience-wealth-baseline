          <annotation class='point' id='1' mark-position='1' pullback='0' text-width='224'>
            <formatted-text>
              <run bold='true' fontalignment='0' fontcolor='#555555' fontname='Benton Sans Book'>Peak Rate Pressure:</run>
              <run fontalignment='0' fontcolor='#555555' fontname='Benton Sans Book'> With interest rates held at 5.25%, consumers increasingly relied on credit cards to cover cash flow shortfalls, pushing outstanding balances from </run>
              <run bold='true' fontalignment='0' fontcolor='#555555' fontname='Benton Sans Book'>$90B</run>
              <run fontalignment='0' fontcolor='#555555' fontname='Benton Sans Book'> to </run>
              <run bold='true' fontalignment='0' fontcolor='#555555' fontname='Benton Sans Book'>over $105B</run>
              <run fontalignment='0' fontcolor='#555555' fontname='Benton Sans Book'>.</run>
            </formatted-text>
            <point>
              <visual-coordinate class='axis'>
                <x-coord axis-value='#2023-11-24 15:46:58.983#'>
