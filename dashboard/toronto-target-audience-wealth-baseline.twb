  <worksheets>
    <worksheet name='Interest vs. Credit Debt'>
      <layout-options>
        <caption>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>This chart highlights the gap between monetary policy and consumer behavior. While the Bank of Canada kept interest rates above </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>5%</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> through 2024, credit card debt continued rising, surpassing </run>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>$115B</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'> as households relied on revolving credit to manage cash flow.</run>
            <run>Æ&#10;</run>
            <run fontcolor='#000000' fontname='Benton Sans Book'>For banks, this presents a clear opportunity. Although rates have declined, many households remain burdened by high-interest debt, making them strong candidates for debt consolidation loans and HELOCs.</run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='master_macroeconomic_matrix' name='federated.0n153dd09qbgb41crivlf0tpn9dp' />
          </datasources>
          <datasource-dependencies datasource='federated.0n153dd09qbgb41crivlf0tpn9dp'>
            <column datatype='real' name='[Bank rate]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Credit cards]' role='measure' type='quantitative' />
            <column caption='Ref Date' datatype='date' datatype-customized='true' name='[REF_DATE]' role='dimension' type='ordinal' />
            <column-instance column='[Bank rate]' derivation='Sum' name='[sum:Bank rate:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Credit cards]' derivation='Sum' name='[sum:Credit cards:qk]' pivot='key' type='quantitative' />
            <column-instance column='[REF_DATE]' derivation='Month-Trunc' name='[tmn:REF_DATE:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style>
          <style-rule element='axis'>
            <encoding attr='space' class='0' field='[federated.0n153dd09qbgb41crivlf0tpn9dp].[sum:Bank rate:qk]' field-type='quantitative' fold='true' scope='rows' type='space' />
            <encoding attr='space' class='0' domain-expand='false' field='[federated.0n153dd09qbgb41crivlf0tpn9dp].[sum:Credit cards:qk]' field-type='quantitative' scope='rows' type='space' />
          </style-rule>
